# --- Contact form / nodemailer (SMTP) ---------------------------------------
# Template only — DO NOT put real secrets here (this file is committed to git).
# Copy this to ".env" (which is gitignored) and fill in the real values there.
#
# Gmail example: host smtp.gmail.com, port 465, and use an "App Password"
#   (Google account -> Security -> App passwords), NOT the normal password.
# Office365 example: host smtp.office365.com, port 587.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-mailbox@gmail.com
SMTP_PASS=your-app-password-here

# Where enquiries are delivered (defaults to cdt.orders@gmail.com if unset).
MAIL_TO=cdt.orders@gmail.com
# The visible "from" address (defaults to SMTP_USER if unset).
MAIL_FROM=your-mailbox@gmail.com
